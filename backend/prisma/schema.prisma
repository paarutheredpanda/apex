generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum ProjectStatus {
  active
  paused
  completed
}

model Project {
  id          String        @id @default(uuid())
  userId      String
  name        String
  description String        @default("")
  status      ProjectStatus @default(active)
  createdAt   DateTime      @default(now())

  @@index([userId])
}
