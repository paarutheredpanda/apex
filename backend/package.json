{
  "name": "apex-backend",
  "version": "1.0.0",
  "description": "APEX Backend — Node.js + Express REST API",
  "main": "dist/index.js",
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only src/index.ts",
    "build": "npx prisma generate && tsc",
    "start": "node dist/index.js",
    "lint": "eslint \"src/**/*.ts\"",
    "lint:fix": "eslint \"src/**/*.ts\" --fix",
    "type-check": "tsc --noEmit"
  },
  "dependencies": {
    "@clerk/express": "^2.1.21",
    "@prisma/adapter-pg": "^7.8.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.22.2",
    "next": "9.3.3",
    "pg": "^8.21.0"
  },
  "devDependencies": {
    "@prisma/client": "^6.19.3",
    "@types/cors": "^2.8.19",
    "@types/express": "^4.17.25",
    "@types/node": "^20.12.12",
    "@types/pg": "^8.20.0",
    "@typescript-eslint/eslint-plugin": "^7.10.0",
    "@typescript-eslint/parser": "^7.10.0",
    "effect": "^3.21.0",
    "empathic": "^2.0.0",
    "eslint": "^8.57.0",
    "fast-check": "^3.23.2",
    "prisma": "^6.19.3",
    "pure-rand": "^6.1.0",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.4.5"
  }
}
